# ── Copy this to .env and fill in real values ─────────────────────────────
# On HuggingFace Spaces: Settings → Variables and Secrets → New Secret
# NEVER commit .env to git.

PORT=7860
NODE_ENV=production

# ── Admin login (stored only in env, never in code) ───────────────────────
ADMIN_EMAIL=your-admin-email@sdmodelkarnal.edu
ADMIN_PASSWORD=YourStrongPassword123!
ADMIN_NAME=Mrs. Amita Singh

# ── JWT secret — generate with: ───────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex-string

# ── School info (used in email templates) ─────────────────────────────────
SCHOOL_NAME=S.D. Model Sr. Sec. School, Karnal
SCHOOL_DOMAIN=sdmodelkarnal.edu

# ── MongoDB Atlas (direct connection, avoids SRV DNS blocks) ──────────────
MONGODB_URI=mongodb://user:password@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/sdmodel?ssl=true&authSource=admin&retryWrites=true&w=majority

# ── CORS — use * on HuggingFace (single Docker container) ─────────────────
CORS_ORIGIN=*
