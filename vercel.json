{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/index.cjs": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.cjs" },
    { "source": "/(.*)",       "destination": "/api/index.cjs" }
  ]
}
